def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z')


def normalize_text(text: str) -> str:
    return ' '.join((text or '').strip().lower().split())


def detect_signals(req: DecisionRequest) -> Dict[str, Any]:
    text = normalize_text(req.message_text or '')
    irritacao_terms = [
        'demorando', 'ninguém resolve', 'ninguem resolve', 'absurdo', 'ridículo', 'ridiculo',
        'sacanagem', 'frustrado', 'frustrada', 'irritado', 'irritada', 'irritante', 'péssimo',
        'pessimo', 'horrível', 'horrivel', 'faz tempo', 'até agora nada', 'ate agora nada'
    ]
    specific_tech_names = ['erivelton', 'willian', 'breno']
    saudacoes = ['oi', 'ola', 'olá', 'bom dia', 'boa tarde', 'boa noite']
    first_message = not bool(req.contexto.last_status or req.contexto.last_intent or req.contexto.updated_at)
    identified = bool(req.contexto.identificado or (req.contexto.nome and req.contexto.empresa))
    only_greeting = text in saudacoes
    short_reply = text in {'sim', 'isso', 'ok', 'certo', 'pode ser', 'pode', 'segue', 'continue', 'continua'}
    return {
        'text': text,
        'first_message': first_message,
        'identified': identified,
        'pediu_tecnico_especifico': any(name in text for name in specific_tech_names),
        'cliente_irritado': any(term in text for term in irritacao_terms),
        'only_greeting': only_greeting,
        'short_reply': short_reply,
        'ambiguous_contact': bool(req.contact.ambiguous_contact),
        'closed_event': req.event_type in {'closed', 'conversation_closed', 'finalized'},
        'ultima_solicitacao_tipo': req.contexto.ultima_solicitacao_tipo or '',
        'last_status': req.contexto.last_status or '',
        'last_intent': req.contexto.last_intent or ''
    }


def fallback_response(req: DecisionRequest, signals: Optional[Dict[str, Any]] = None, intent: str = 'fallback_local') -> Dict[str, Any]:
    signals = signals or detect_signals(req)
    if signals['closed_event']:
        status = 'ENCERRADO'
        msg = '[BOT] Atendimento finalizado.'
        handoff = False
        intent = 'closed_cleanup'
        req_type = req.contexto.ultima_solicitacao_tipo
    elif signals['ambiguous_contact']:
        status = 'IDENTIFICACAO'
        msg = '[BOT] Para seguir com segurança, me informe seu nome completo e empresa 🙂'
        handoff = True
        req_type = 'identificacao'
    elif signals['identified']:
        status = 'TRIAGEM'
        if signals['short_reply'] and req.contexto.last_status:
            msg = '[BOT] Perfeito 🙂 Pode me passar mais detalhes do ocorrido?'
        else:
            msg = '[BOT] Me conte, por gentileza, o que está acontecendo para eu direcionar melhor 🙂'
        handoff = False
        req_type = 'triagem'
    else:
        status = 'IDENTIFICACAO'
        if signals['first_message']:
            msg = '[BOT] Olá 🙂 Sou o assistente virtual em treinamento. Para agilizar, prefira enviar uma única mensagem com mais detalhes. Me informe seu nome completo e empresa, por gentileza.'
        else:
            msg = '[BOT] Me informe seu nome completo e empresa, por gentileza 🙂'
        handoff = False
        req_type = 'identificacao'
    updated = {
        **req.contexto.model_dump(),
        'protocolo': req.protocol,
        'numero': req.customer_id,
        'updated_at': now_iso(),
        'last_status': status,
        'last_intent': intent,
        'last_event_type': req.event_type,
        'ultima_solicitacao_tipo': req_type,
    }
    if status == 'ENCERRADO':
        updated['encerrado'] = True
    return {
        'decisao': {
            'status': status,
            'intent': intent,
            'mensagem': msg,
            'confidence': 0.55,
            'abrir_ticket': False,
            'agendar': False,
            'handoff_humano': handoff,
        },
        'contexto_atualizado': updated,
        'meta': {'source': 'bridge_fallback_v2_1', 'fallback_used': True},
    }


